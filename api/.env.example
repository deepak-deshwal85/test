# Embeddings (required for ingest and search)
# OPENAI_API_KEY=

# Qdrant — local Docker OR Qdrant Cloud
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_CLUSTER_ENDPOINT=https://your-cluster.aws.cloud.qdrant.io
# QDRANT_CLUSTER_NAME=your_cluster_name
# QDRANT_API_KEY=

# PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/relaydesk

# OAuth2 (AWS Cognito) — set OAUTH_DISABLED=true for local dev without Cognito
# COGNITO_REGION=ap-south-1
# COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
# COGNITO_UI_CLIENT_ID=
# COGNITO_M2M_CLIENT_ID=
# COGNITO_REQUIRED_SCOPE=relaydesk-api/access
# OAUTH_DISABLED=true

# Outbound calls via LiveKit SIP (required for real dialing)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# LIVEKIT_AGENT_NAME=relaydesk-agent

# Optional overrides
# RAG_BACKEND=qdrant
# RAG_MAX_RESULTS=5
# RAG_MIN_SCORE=0.3
