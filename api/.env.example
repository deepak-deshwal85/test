# Embeddings (required for ingest and search)
# OPENAI_API_KEY=

# Qdrant — local Docker OR Qdrant Cloud
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_CLUSTER_ENDPOINT=https://your-cluster.aws.cloud.qdrant.io
# QDRANT_CLUSTER_NAME=your_cluster_name
# QDRANT_API_KEY=

# PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/telephone_agent

# RAG API server
# RAG_API_HOST=0.0.0.0
# RAG_API_PORT=8090
# RAG_API_KEY=

# Outbound calls via LiveKit SIP (required for real dialing)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# LIVEKIT_AGENT_NAME=telephone-agent

# Optional overrides
# RAG_BACKEND=qdrant
# RAG_MAX_RESULTS=5
