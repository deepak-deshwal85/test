# Embeddings (required for ingest and search)
# OPENAI_API_KEY=

# Qdrant
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=

# PostgreSQL
# DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/telephone_agent

# RAG API server
# RAG_API_HOST=0.0.0.0
# RAG_API_PORT=8090
# RAG_API_KEY=

# Outbound calls (optional webhook for real telephony integration)
# OUTBOUND_CALL_WEBHOOK_URL=

# Optional overrides
# RAG_BACKEND=qdrant
# RAG_MAX_RESULTS=5
