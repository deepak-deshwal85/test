# Embeddings
OPENAI_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/relaydesk

# Qdrant — local Docker OR Qdrant Cloud
# QDRANT_URL=http://127.0.0.1:6333
QDRANT_CLUSTER_ENDPOINT=https://your-cluster.aws.cloud.qdrant.io
QDRANT_CLUSTER_NAME=
QDRANT_API_KEY=

# RAG API server
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8090

# OAuth2 (AWS Cognito). Set OAUTH_DISABLED=true for local API without JWT validation.
# OAUTH_DISABLED=true
COGNITO_REGION=ap-south-1
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_UI_CLIENT_ID=
COGNITO_M2M_CLIENT_ID=
COGNITO_REQUIRED_SCOPE=relaydesk-api/access

# Outbound calls via LiveKit SIP
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_AGENT_NAME=relaydesk-agent

# Optional
# RAG_BACKEND=qdrant
# RAG_MAX_RESULTS=5
# RAG_MIN_SCORE=0.3
# CORS_ORIGINS=http://localhost:3000
