# Embeddings
OPENAI_API_KEY=

# PostgreSQL — AWS RDS via SSM tunnel (see infra/scripts/rds_tunnel.py)
# Terminal 1: python infra/scripts/rds_tunnel.py start
# Terminal 2: python infra/scripts/rds_tunnel.py write-env --password <RDS_PASSWORD>
# Writes api/.env.local with DATABASE_URL=...@127.0.0.1:15432/relaydesk
DATABASE_URL=postgresql+asyncpg://relaydesk_admin:PASSWORD@127.0.0.1:15432/relaydesk

# Qdrant Cloud (required for local and production API)
QDRANT_CLUSTER_ENDPOINT=https://your-cluster.aws.cloud.qdrant.io
QDRANT_CLUSTER_NAME=
QDRANT_API_KEY=

# RAG API server
RAG_API_HOST=0.0.0.0
RAG_API_PORT=8090

# OAuth2 (AWS Cognito). Set OAUTH_DISABLED=true for local API without JWT validation.
OAUTH_DISABLED=true
COGNITO_REGION=ap-south-1
COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
COGNITO_UI_CLIENT_ID=
COGNITO_M2M_CLIENT_ID=
COGNITO_REQUIRED_SCOPE=relaydesk-api/access

# Outbound calls via LiveKit SIP
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_AGENT_NAME=relaydesk-agent

# Optional
# RAG_BACKEND=qdrant
# RAG_MAX_RESULTS=5
# RAG_MIN_SCORE=0.3
# CORS_ORIGINS=http://localhost:3000
