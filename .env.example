LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Provider API keys (direct APIs, bypass LiveKit Inference quota)
DEEPGRAM_API_KEY=
XAI_API_KEY=

# Cal.com scheduling (https://cal.com/docs/agents)
CALCOM_API_KEY=
# CALCOM_BASE_URL=https://api.cal.com
# CALCOM_API_VERSION=2024-08-13

# Speech models
STT_MODEL=nova-3
XAI_LLM_MODEL=grok-4-1-fast-non-reasoning
XAI_TTS_VOICE=ara
# XAI_FILE_SEARCH_MAX_RESULTS=5
# MEETING_TIMEZONE=Asia/Kolkata
# CALCOM_API_VERSION=2024-09-04
