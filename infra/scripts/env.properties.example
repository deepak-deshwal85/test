# Copy to env.properties and fill in values (do not commit env.properties).
# Or generate from local .env files:
#   python infra/scripts/sync_ssm_parameters.py --write-env-properties --from-local-env
#
# Then upload to AWS:
#   python infra/scripts/sync_ssm_parameters.py --region ap-south-1

# --- API (/relaydesk/prod/api/*) ---
OPENAI_API_KEY=
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST:5432/relaydesk
RAG_API_KEY=
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=https://your-cluster.aws.cloud.qdrant.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# --- Voice agent (/relaydesk/prod/voice-agent/*) ---
# LIVEKIT_*, RAG_API_KEY are shared with API — set once above
XAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CALCOM_API_KEY=
