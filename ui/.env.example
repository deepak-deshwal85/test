# NextAuth / Cognito OAuth2
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3000

# Set true only for local development to bypass SSO.
AUTH_DISABLE_SSO=false

# AWS Cognito OIDC
COGNITO_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/ap-south-1_XXXXXXXXX
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# API routing mode:
# - local: always use RELAYDESK_API_URL_LOCAL
# - aws: always use RELAYDESK_API_URL_AWS
# - auto: local in dev, aws in production
RELAYDESK_API_TARGET=auto
RELAYDESK_API_URL_LOCAL=http://127.0.0.1:8090
RELAYDESK_API_URL_AWS=http://relaydesk-prod-api-xxxxx.ap-south-1.elb.amazonaws.com

# Optional override for both modes
# RELAYDESK_API_URL=http://127.0.0.1:8090
