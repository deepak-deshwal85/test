# NextAuth / Cognito OAuth2
AUTH_SECRET=change-me-to-a-random-secret
AUTH_URL=http://localhost:3000

# Production (recommended): AWS Cognito user pool + federated Google/GitHub
COGNITO_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/ap-south-1_XXXXXXXXX
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# Local dev fallback when Cognito is not configured (tokens are not accepted by API unless OAUTH_DISABLED=true)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# RelayDesk API base URL (server-side)
RELAYDESK_API_URL=http://127.0.0.1:8090
