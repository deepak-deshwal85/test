# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# STT / LLM / TTS
XAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CALCOM_API_KEY=

# Agent identity
AGENT_NAME=relaydesk-agent
CLIENT_PHONE_OVERRIDE=+911171366880

# RAG — call the API service
RAG_BACKEND=qdrant
RAG_API_BASE_URL=http://127.0.0.1:8090

# Cognito M2M (client credentials) — used when production API requires OAuth
COGNITO_TOKEN_URL=https://relaydesk-prod.auth.ap-south-1.amazoncognito.com/oauth2/token
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_SCOPE=relaydesk-api/access
